# --- Node API (backend/) — apply form + admin API ---
# Same URL for both; no trailing slash. Node API (apply form + admin). Server: BASE_URL; browser: NEXT_PUBLIC_BASE_URL.
BASE_URL=https://onyxx-logic-jdbp8.ondigitalocean.app
NEXT_PUBLIC_BASE_URL=https://onyxx-logic-jdbp8.ondigitalocean.app
# Local dev:
# BASE_URL=http://127.0.0.1:4000
# NEXT_PUBLIC_BASE_URL=http://127.0.0.1:4000

# Same value as backend JWT_SECRET (signs admin JWT after DB login; Next verifies cookie).
JWT_SECRET=use-a-long-random-string
# Alternative name (either works in Next + backend):
# ADMIN_SESSION_SECRET=use-a-long-random-string

# --- PostgreSQL ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# PG_POOL_MAX=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=onyxx
